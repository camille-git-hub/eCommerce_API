{
  "name": "wbs-node-ts-template",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "type": "module",
  "imports": {
    "#controllers": {
      "development": "./src/controllers/index.ts",
      "default": "/dist/controllers/index.js"
    },
    "#middleware": {
      "development": "./src/middleware/index.ts",
      "default": "/dist/middleware/index.js"
    },
    "#schemas": {
      "development": "./src/schemas/index.ts",
      "default": "/dist/schemas/index.js"
    },
    "#models": {
      "development": "./src/models/index.ts",
      "default": "/dist/models/index.js"
    },
    "#routes": {
      "development": "./src/routes/index.ts",
      "default": "/dist/routes/index.js"
    }
  },
  "scripts": {
    "dev": "node --watch --conditions development --env-file=.env.development.local src/app.ts",
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.12",
    "@types/swagger-ui": "^5.21.1",
    "@types/swagger-ui-express": "^4.1.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "express": "^5.2.1",
    "mongoose": "^9.2.4",
    "node": "^22.22.1",
    "swagger-ui": "^5.32.0",
    "swagger-ui-dist": "^5.32.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
